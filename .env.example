# Required for Cloudflare Pages — set these as environment variables/secrets in the Cloudflare dashboard:
# SHEET_ID=your_google_sheet_id
# GOOGLE_CLIENT_EMAIL=your_service_account_email
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_SECRET=your_jwt_secret
# ADMIN_USERNAME=your_admin_username
# ADMIN_PASSWORD_HASH=sha256_of_your_password
#
# Also configured in script.js:
# WHATSAPP_NUMBER=201027993246
# INSTAPAY_PHONE=your_instapay_phone
# INSTAPAY_NAME=your_instapay_name
